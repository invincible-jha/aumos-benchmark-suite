# AumOS Benchmark Suite — environment variables
# Copy to .env and fill in values for local development.
# All vars use the AUMOS_BENCHMARK_ prefix.

# ---- Database ----
AUMOS_BENCHMARK_DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_benchmark

# ---- Kafka ----
AUMOS_BENCHMARK_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_BENCHMARK_KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ---- Upstream services ----
AUMOS_BENCHMARK_TABULAR_ENGINE_URL=http://localhost:8004
AUMOS_BENCHMARK_PRIVACY_ENGINE_URL=http://localhost:8010
AUMOS_BENCHMARK_FIDELITY_VALIDATOR_URL=http://localhost:8013

# ---- Benchmark runner ----
AUMOS_BENCHMARK_MAX_CONCURRENT_RUNS=4
AUMOS_BENCHMARK_RUN_TIMEOUT_SECONDS=3600
AUMOS_BENCHMARK_DATASET_STORAGE_PATH=/data/benchmarks/datasets
AUMOS_BENCHMARK_CONFIG_PATH=/data/benchmarks/configs

# ---- Regression thresholds ----
AUMOS_BENCHMARK_FIDELITY_REGRESSION_THRESHOLD=0.05
AUMOS_BENCHMARK_PRIVACY_REGRESSION_THRESHOLD=0.03
AUMOS_BENCHMARK_SPEED_REGRESSION_THRESHOLD_PERCENT=20.0

# ---- Baselines ----
AUMOS_BENCHMARK_BASELINE_STALENESS_DAYS=30

# ---- Reports ----
AUMOS_BENCHMARK_REPORT_OUTPUT_PATH=/data/benchmarks/reports

# ---- HTTP client ----
AUMOS_BENCHMARK_HTTP_TIMEOUT=60.0
AUMOS_BENCHMARK_HTTP_MAX_RETRIES=3

# ---- Auth (from aumos-common) ----
AUMOS_JWT_SECRET=change-me-in-production
AUMOS_JWT_ALGORITHM=HS256
